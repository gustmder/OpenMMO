# Agent client configuration

# Server WebSocket URL. Straight to the game port on the server machine;
# through the public TLS front door from anywhere else, where the proxy only
# upgrades the /ws path (the bare host serves the game page instead):
#   server = "wss://openmmo.to.nexus/ws"
server = "ws://127.0.0.1:10006"

# Where heightmap tiles come from. A local terrain directory when running on
# the game server; an http(s):// server origin otherwise — the same public
# endpoint the web client reads, so no 3 GB tile tree to copy around.
# terrain = "https://openmmo.to.nexus"
terrain = "../data/terrain"

# Disk cache for tiles fetched over HTTP (ignored for a local terrain dir).
# terrain_cache = "data/cache/height"

# NPC auth token. Defaults to reading ../data/npc_token (generated by the
# server on first run); set here only when running on a different machine.
# npc_token = "..."

# NPC account name (must start with npc_); auto-created on first use.
account = "npc_example"

# MCP HTTP server port (default: 8808)
# mcp_port = 8808

# LLM backend to use: "none", "claude", "openrouter", "codex"
# - none: no LLM driver (MCP or direct mode)
# - claude: Claude CLI (stdio subprocess)
# - openrouter: OpenRouter API (HTTP, any model)
# - codex: Codex CLI (stdio subprocess)
llm = "none"

# LLM timing (seconds)
min_interval_secs = 5                       # Minimum seconds between prompts (active mode)
debounce_secs = 2                           # Extra wait to batch events after trigger
idle_interval_secs = 3600                   # Interval when no chat/combat activity (idle mode)
activity_window_secs = 30                   # How long after last activity to stay in active mode

# LLM Scheduler: controls concurrent LLM calls across all NPCs
max_concurrent = 2                          # Max simultaneous LLM calls (default: 2)

# How this client authenticates to the game server.
#   npc_token — shared secret from the server's data/npc_token (default)
#   google    — the runner's own Google account, via the device flow: the
#               client prints a URL and a code to enter in any browser
[auth]
mode = "npc_token"
# client_id = "...apps.googleusercontent.com"  # defaults to the built-in CLI client
# client_secret = "..."                        # or GOOGLE_CLI_CLIENT_SECRET
# token_cache = "~/.config/onlinerpg/google.json"  # refresh token lives here (0600)

# Claude CLI settings (used when llm = "claude")
[claude]
model = "sonnet"                            # "sonnet", "opus", "haiku", or full model ID
system_prompt_file = "data/system_prompt.txt"  # Path to system prompt file

# OpenRouter API settings (used when llm = "openrouter")
# Uses OpenAI-compatible chat completions API to call any model available on OpenRouter.
[openrouter]
# api_key = "sk-or-..."                        # Or set OPENROUTER_API_KEY env var
model = "openrouter/hunter-alpha"              # Any model ID from openrouter.ai/models
system_prompt_file = "data/system_prompt.txt"
max_tokens = 1024                              # Max response tokens
temperature = 0.7

# Codex CLI settings (used when llm = "codex")
# Requires `codex` CLI installed (npm i -g @openai/codex) and OPENAI_API_KEY set.
[codex]
model = "gpt-5.4-mini"                                # Any OpenAI model ID
system_prompt_file = "data/system_prompt.txt"

# --- Multi-NPC Orchestrator Mode ---
# When [[npcs]] is present, legacy single-NPC fields above are ignored.
# Each NPC gets its own WebSocket connection and LLM session.
#
# Who an NPC *is* lives in the game-data registry (data-src/npcs.csv) and the
# data/npcs/{id}/ directory; this file only picks which registry NPCs run on
# this instance and with what deployment values (account, llm, timing).
# With `id` set, these are derived from the registry:
#   character_name  = registry npcName
#   character_class = registry class
#   template_prompt = data/templates/{class}.txt
#   instance_prompt = data/npcs/{id}/instance.txt
#   memory_file     = data/npcs/{id}/memory.txt
#   schedule_file   = data/npcs/{id}/schedule.json (when the file exists)
# Any of them can still be set explicitly to override the convention, and an
# entry without `id` keeps working fully spelled out (ad-hoc NPCs).

[[npcs]]
id = "karl"
account = "npc_guard"
llm = "codex"

# Per-NPC timing overrides (optional, defaults shown above)
# min_interval_secs = 5
# debounce_secs = 2
# idle_interval_secs = 3600
# activity_window_secs = 30

[[npcs]]
id = "rica"
account = "npc_merchant"
llm = "codex"
