# Agent client configuration

# Server WebSocket URL
server = "ws://127.0.0.1:10015"

# Account credentials
account = ""
password = ""

# Set to true to create a new account instead of logging in
create_account = false

# Character ID to enter game with
# If omitted, starts MCP HTTP server and waits for LLM to select a character
# character_id = 1

# MCP HTTP server port (default: 8808)
# Used when character_id is not set (MCP polling mode)
# mcp_port = 8808

# LLM backend to use: "none", "claude", "openrouter"
# - none: no LLM driver (MCP or direct mode)
# - claude: Claude CLI (stdio subprocess)
# - openrouter: OpenRouter API (HTTP, any model)
llm = "none"

# Claude CLI settings (used when llm = "claude")
[claude]
model = "sonnet"                            # "sonnet", "opus", "haiku", or full model ID
min_interval_secs = 5                       # Minimum seconds between prompts (includes debounce)
debounce_secs = 2                           # Extra wait to batch events when min_interval already passed
system_prompt_file = "data/system_prompt.txt"  # Path to system prompt file

# OpenRouter API settings (used when llm = "openrouter")
# Uses OpenAI-compatible chat completions API to call any model available on OpenRouter.
[openrouter]
# api_key = "sk-or-..."                        # Or set OPENROUTER_API_KEY env var
model = "openrouter/hunter-alpha"              # Any model ID from openrouter.ai/models
min_interval_secs = 5
debounce_secs = 2
system_prompt_file = "data/system_prompt.txt"
max_tokens = 1024                              # Max response tokens
temperature = 0.7
